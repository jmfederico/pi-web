{
  "name": "@jmfederico/pi-web-tunnel",
  "version": "0.0.0",
  "description": "Local connector CLI for PI WEB Safe Tunnels.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pi-web-tunnel": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "connector": "tsx ./src/cli.ts"
  },
  "dependencies": {
    "@jmfederico/pi-web-tunnel-frp-engine": "0.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  }
}
