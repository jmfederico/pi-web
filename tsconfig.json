{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "noEmit": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node"
    ],
    "paths": {
      "@jmfederico/pi-web/plugin-api": [
        "./src/plugin-api.ts"
      ],
      "@jmfederico/pi-web/plugin-api/unstable": [
        "./src/plugin-api/unstable.ts"
      ],
      "@jmfederico/pi-web-tunnel-frp-engine": [
        "./packages/tunnel-frp-engine/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "extensions/**/*.ts",
    "pi-web-plugins/**/*.ts",
    "packages/**/*.ts"
  ],
  "exclude": [
    "coverage",
    "dist",
    "node_modules",
    "packages/*/dist"
  ]
}
